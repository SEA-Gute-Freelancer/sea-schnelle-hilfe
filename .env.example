# Telegram Bot (required)
# Token from BotFather — set in Vercel dashboard, never commit the real value
TELEGRAM_TOKEN=your_bot_token_here

# Telegram Group Chat ID (required)
# Get it by adding @userinfobot to your group
TELEGRAM_CHAT_ID=-1001234567890

# Upstash Redis (optional — for two-way replies)
# Free tier at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
